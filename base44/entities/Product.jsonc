{
  "name": "Product",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nom du produit"
    },
    "category": {
      "type": "string",
      "enum": [
        "tabac",
        "alimentaire",
        "hygiene",
        "elevage"
      ],
      "default": "alimentaire"
    },
    "description": {
      "type": "string"
    },
    "unit_price": {
      "type": "number",
      "description": "Prix unitaire (FCFA)"
    },
    "wholesale_price": {
      "type": "number",
      "description": "Prix grossiste (FCFA)"
    },
    "stock_quantity": {
      "type": "number",
      "default": 0
    },
    "stock_alert": {
      "type": "number",
      "default": 10,
      "description": "Seuil d'alerte stock"
    },
    "unit": {
      "type": "string",
      "default": "carton",
      "description": "Unit\u00e9 (carton, sac, bouteille...)"
    },
    "image_url": {
      "type": "string"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "show_on_vitrine": {
      "type": "boolean",
      "default": false,
      "description": "Afficher ce produit sur le site vitrine public"
    },
    "display_order": {
      "type": "number",
      "default": 999,
      "description": "Ordre d'affichage sur la vitrine (plus petit = affich\u00e9 en premier)"
    }
  },
  "required": [
    "name",
    "unit_price"
  ]
}